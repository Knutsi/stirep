{
  "name": "@knutsi/sitflow",
  "version": "0.1.0",
  "exports": "./app.ts",
  "tasks": {
    "dev": "deno run --allow-net --watch app.ts",
    "start": "deno run --allow-net app.ts",
    "check": "deno check .",
    "test": "deno test"
  },
  "imports": {
    "hono": "npm:hono@^4.12.27",
    "hono/": "npm:hono@^4.12.27/",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^1.4.0",
    "@scalar/hono-api-reference": "npm:@scalar/hono-api-reference@^0.11.8",
    "zod": "npm:zod@^4.4.3"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
